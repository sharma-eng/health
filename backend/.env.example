PORT=4000
CORS_ORIGIN=http://localhost:3000

# LLM provider key (e.g. OpenAI) for real analysis (optional)
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
OPENAI_MODEL=gpt-4.1-mini

# Junction Health API key for wearable integrations (optional)
JUNCTION_API_KEY=<YOUR_JUNCTION_API_KEY>
JUNCTION_BASE_URL=https://api.sandbox.tryvital.io
JUNCTION_DEMO_USER_ID=<YOUR_DEMO_USER_ID>

# Postgres connection string (optional; enables persistence)
DATABASE_URL=<YOUR_DATABASE_URL>

# Canopy API key for Amazon product lookup (enables real product search)
CANOPY_API_KEY=<YOUR_CANOPY_API_KEY>

# Amazon marketplace for Canopy (defaults to US)
CANOPY_DOMAIN=US

# Override if Canopy changes base URL; defaults to production
CANOPY_BASE_URL=https://rest.canopyapi.co


